<svg width="100%" viewBox="0 0 680 200" role="img" xmlns="http://www.w3.org/2000/svg">
<title>Electric shock themed divider banner</title>
<desc>Animated lightning bolt with electric arcs and sparks on a dark navy background, in yellow and blue colors</desc>
<style>
.bg{fill:#0A0F1E}
.bolt{fill:#FFD700}
.boltGlow{fill:#FFD700;opacity:0.25}
.arc{fill:none;stroke:#3D8BFF;stroke-width:2;stroke-linecap:round}
.spark{fill:#FFD700}
.txt{font-family:monospace;font-size:13px;fill:#3D8BFF;letter-spacing:2px}
</style>
<rect class="bg" x="0" y="0" width="680" height="200" rx="10"/>
<g>
<ellipse class="boltGlow" cx="340" cy="100" rx="90" ry="80">
<animate attributeName="opacity" values="0.1;0.35;0.1" dur="1.4s" repeatCount="indefinite"/>
</ellipse>
</g>
<path class="arc" d="M120 60 Q150 90 110 100 Q160 110 130 140">
<animate attributeName="opacity" values="0.2;1;0.2" dur="0.6s" repeatCount="indefinite"/>
</path>
<path class="arc" d="M560 50 Q530 80 570 95 Q520 105 550 135">
<animate attributeName="opacity" values="1;0.2;1" dur="0.8s" repeatCount="indefinite"/>
</path>
<path class="bolt" d="M360 30 L300 110 L335 110 L310 175 L390 90 L350 90 Z">
<animate attributeName="opacity" values="1;0.55;1" dur="0.35s" repeatCount="indefinite"/>
</path>
<circle class="spark" cx="200" cy="60" r="3">
<animate attributeName="opacity" values="0;1;0" dur="0.9s" repeatCount="indefinite"/>
</circle>
<circle class="spark" cx="480" cy="150" r="3">
<animate attributeName="opacity" values="0;1;0" dur="1.1s" begin="0.3s" repeatCount="indefinite"/>
</circle>
<circle class="spark" cx="230" cy="160" r="2.5">
<animate attributeName="opacity" values="0;1;0" dur="0.7s" begin="0.5s" repeatCount="indefinite"/>
</circle>
<circle class="spark" cx="500" cy="55" r="2.5">
<animate attributeName="opacity" values="0;1;0" dur="1s" begin="0.2s" repeatCount="indefinite"/>
</circle>
<text class="txt" x="340" y="190" text-anchor="middle">teus123321</text>
</svg>
